# Anthropic API key — used by the probability brain (not required for /health).
ANTHROPIC_API_KEY=

# Circle developer-controlled wallet credentials — used by the wallet engine
# (not required for /health). Entity secret public key is the RSA-OAEP key
# Circle provides per developer; the entity secret itself is never stored
# here, it is supplied per request from a secret manager.
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET_PUBLIC_KEY=

# HTTP server port (default 8787). Note: wrangler defaults to 8787 too —
# change if running both apps/edge and services/core locally on the same host.
PORT=8787
